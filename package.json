{
  "name": "codesage",
  "version": "0.1.0",
  "description": "AI code review engine powered by Claude Code",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "codesage": "dist/cli/index.js"
  },
  "scripts": {
    "build": "rm -rf dist && tsup && cp -r src/skills dist/skills",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit"
  },
  "keywords": [
    "code-review",
    "ai",
    "claude",
    "gitee",
    "github"
  ],
  "author": "Novar <xuwab77@gmail.com>",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@fastify/cors": "^11.2.0",
    "better-sqlite3": "^12.8.0",
    "chalk": "^5.6.2",
    "commander": "^14.0.3",
    "fastify": "^5.8.4",
    "picomatch": "^4.0.4",
    "simple-git": "^3.35.2",
    "yaml": "^2.8.3"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.5.2",
    "@types/picomatch": "^4.0.3",
    "tsup": "^8.5.1",
    "typescript": "^6.0.2",
    "vitest": "^4.1.3"
  }
}
